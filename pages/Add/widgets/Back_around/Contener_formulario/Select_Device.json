  "sourceData": "{{\n  devices_no_DB.data\n    .filter(d => {\n      const tipoSel = String(TipoRegistro.selectedOptionValue || \"\").toUpperCase().trim();\n      if (!tipoSel) return false;\n      \n      const tipoDev = String(d.type || d.tipo || \"\").toUpperCase().trim();\n      return tipoDev === tipoSel ||\n             (tipoSel.includes(\"FINGER\") && tipoDev.includes(\"FINGER\")) ||\n             (tipoSel.includes(\"RFID\") && tipoDev.includes(\"RFID\"));\n    })\n    .map(d => ({\n      label: String(d.name || d.description || d.serial || `Device ${d.id || \"?\"}`).trim(),\n      value: String(d.id || d.codigo || d.device_id || d.mac || \"\").trim()  // FORÇA STRING SEMPRE!\n    }))\n}}",
